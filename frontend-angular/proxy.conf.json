{
  "/api": {
    "target": "http://localhost:8082",
    "secure": false,
    "changeOrigin": true,
    "pathRewrite": {
      "^/api": "/api"
    },
    "logLevel": "debug"
  },
  "/ws": {
    "target": "http://localhost:8082",
    "secure": false,
    "changeOrigin": true,
    "ws": true,
    "pathRewrite": {
      "^/ws": "/ws"
    }
  }
}
