@startuml
title Attijari Compass - Diagramme de cas d'utilisation global

left to right direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam actorStyle stick
skinparam usecase {
  BackgroundColor #F8FAFC
  BorderColor #334155
  ArrowColor #334155
}

actor "Visiteur" as Visitor
actor "Utilisateur authentifie" as User
actor "Administrateur" as Admin
actor "Service ML\nFastAPI" as ML
actor "Service LLM\nGroq" as Groq

Admin --|> User

rectangle "Systeme Attijari Compass" {
  usecase "Creer un compte" as UC_Register
  usecase "Se connecter" as UC_Login
  usecase "Gerer le profil" as UC_Profile

  usecase "Consulter le dashboard\net les rapports" as UC_Dashboard
  usecase "Gerer les transactions" as UC_Transactions
  usecase "Importer CSV/Excel" as UC_Import
  usecase "Categoriser les transactions" as UC_Categorize

  usecase "Gerer les cartes bancaires" as UC_Cards
  usecase "Synchroniser les\ntransactions carte" as UC_Sync

  usecase "Definir des budgets\net consulter alertes" as UC_Budgets
  usecase "Gerer les objectifs\nfinanciers" as UC_Goals
  usecase "Consulter les\nrecommandations IA" as UC_Reco
  usecase "Utiliser les simulateurs" as UC_Sim
  usecase "Discuter avec le\nchatbot financier" as UC_Chat
  usecase "Gerer les notifications" as UC_Notifs

  usecase "Administrer les utilisateurs" as UC_AdminUsers
}

Visitor --> UC_Register
Visitor --> UC_Login

User --> UC_Profile
User --> UC_Dashboard
User --> UC_Transactions
User --> UC_Import
User --> UC_Cards
User --> UC_Sync
User --> UC_Budgets
User --> UC_Goals
User --> UC_Reco
User --> UC_Sim
User --> UC_Chat
User --> UC_Notifs

Admin --> UC_AdminUsers

UC_Import .> UC_Categorize : <<include>>
UC_Transactions .> UC_Categorize : <<include>>
UC_Cards .> UC_Sync : <<include>>

ML --> UC_Categorize
Groq --> UC_Chat
@enduml
